# Copy this file to .env.local and fill in your keys.
# The app runs fully WITHOUT any keys (in-memory store + heuristic triage),
# so you can demo it immediately. Add keys to enable real Supabase + Gemini.

# --- Google Gemini (https://aistudio.google.com/app/apikey) ---
GEMINI_API_KEY=your-gemini-api-key

# --- Supabase (https://supabase.com -> Project Settings -> API) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Service role key is server-only. Never expose it to the client.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
